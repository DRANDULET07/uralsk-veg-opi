generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductAvailability {
  warehouse
  transit
}

enum ProductStatusTone {
  fresh
  stock
  transit
}

enum ProductUnitMode {
  tons
  kg
}

model Product {
  id            String              @id
  name          String
  subtitle      String
  imageUrl      String
  statusEmoji   String
  statusText    String
  statusTone    ProductStatusTone
  availability  ProductAvailability
  basePrice     Int
  minOrder      String?
  location      String
  warehouseId   String?
  bookingNote   String?
  unitMode      ProductUnitMode
  sliderMin     Float
  sliderMax     Float
  sliderStep    Float
  defaultVolume Float
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([availability])
  @@index([warehouseId])
  @@index([isActive])
}
